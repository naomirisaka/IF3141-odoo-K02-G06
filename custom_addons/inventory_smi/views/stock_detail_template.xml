<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="stock_detail_page" name="SMI Stock Detail">
    <t t-call="inventory_smi.layout">
        <t t-set="page_title">Detail Stok</t>

        <!-- Back + actions -->
        <div class="smi-toolbar">
            <a href="/smi/stok" class="smi-btn smi-btn--secondary smi-btn--sm">← Kembali ke Daftar Stok</a>
            <t t-if="not is_direktur">
                <a href="/smi/stok/tambah" class="smi-btn smi-btn--primary smi-btn--sm">+ Tambah Stok</a>
            </t>
        </div>

        <!-- Material info card -->
        <div class="smi-card" style="margin-bottom:20px;">
            <div class="smi-card__header">
                <span class="smi-card__title">Detail Stok</span>
                <span style="font-size:13px;color:var(--text-muted);font-weight:500;" t-esc="material.name"/>
                <t t-if="material.is_low_stock">
                    <span class="smi-badge smi-badge--low-stock">Sisa Sedikit</span>
                </t>
                <t t-else="">
                    <span class="smi-badge smi-badge--aman">Stok Aman</span>
                </t>
            </div>
            <div class="smi-card__body">
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;">
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Kategori</div>
                        <div style="font-weight:500;" t-esc="material.category_id.name or '—'"/>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Total Stok</div>
                        <div style="font-weight:600;font-size:20px;">
                            <t t-esc="'%.1f' % total_stok"/>
                            <span style="font-size:13px;color:var(--text-muted);margin-left:4px;" t-esc="material.uom_id.name"/>
                        </div>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Stok Minimum</div>
                        <div style="font-weight:500;">
                            <t t-esc="'%.1f' % (material.stok_minimum or 0.0)"/>
                            <span style="font-size:13px;color:var(--text-muted);margin-left:4px;" t-esc="material.uom_id.name"/>
                        </div>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Terakhir Ditambahkan</div>
                        <div style="font-weight:500;">
                            <t t-if="material.last_added_date">
                                <t t-esc="material.last_added_date.strftime('%d %b %Y')"/>
                            </t>
                            <t t-else="">—</t>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit stok for kepala produksi / admin -->
        <t t-if="can_manage_points">
            <div class="smi-card" style="margin-bottom:20px;">
                <div class="smi-card__header">
                    <span class="smi-card__title">Edit Stok</span>
                    <span style="font-size:12px;color:var(--text-muted);">Ubah stok minimum dan lokasi batch stok</span>
                </div>
                <div class="smi-card__body" style="display:grid;gap:18px;">
                    <form method="post" t-att-action="'/smi/stok/' + str(material.id) + '/stok-minimum'" style="display:flex;gap:12px;align-items:end;flex-wrap:wrap;">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div>
                            <label class="form-label" style="font-size:12px;color:var(--text-muted);">Stok Minimum</label>
                            <input type="number" name="stok_minimum" class="smi-input" min="0" step="0.1" t-att-value="'%.1f' % (material.stok_minimum or 0.0)" style="width:160px;"/>
                        </div>
                        <button type="submit" class="smi-btn smi-btn--primary smi-btn--sm">Simpan Stok Minimum</button>
                    </form>
                    <div style="font-size:12px;color:var(--text-muted);">Lokasi stok bisa diubah per batch pada tabel riwayat transaksi di bawah.</div>
                </div>
            </div>
        </t>

        <!-- Order usage card -->
        <div class="smi-card" style="margin-bottom:20px;">
            <div class="smi-card__header">
                <span class="smi-card__title">Dipakai di Order</span>
                <span style="font-size:12px;color:var(--text-muted);">
                    <t t-esc="len(order_usage)"/> order line
                </span>
            </div>
            <div class="smi-card__body" style="padding:0;">
                <t t-if="order_usage">
                    <table class="smi-table">
                        <thead>
                            <tr>
                                <th>Order</th>
                                <th>No. SPK</th>
                                <th>Tanggal</th>
                                <th>Status</th>
                                <th>Dibutuhkan</th>
                                <th>Terpenuhi</th>
                                <th>Mode</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="order_usage" t-as="usage">
                                <tr>
                                    <td style="font-weight:500;" t-esc="usage['order_name']"/>
                                    <td t-esc="usage['no_spk']"/>
                                    <td style="color:var(--text-muted);">
                                        <t t-if="usage['tanggal']">
                                            <t t-esc="usage['tanggal'].strftime('%d %b %Y')"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td>
                                        <t t-if="usage['state'] == 'dikonfirmasi'">
                                            <span class="smi-badge smi-badge--confirmed">Dikonfirmasi</span>
                                        </t>
                                        <t t-elif="usage['state'] == 'selesai'">
                                            <span class="smi-badge smi-badge--done">Selesai</span>
                                        </t>
                                        <t t-else="">
                                            <span class="smi-badge smi-badge--draft" t-esc="usage['state']"/>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-esc="'%.1f' % usage['jumlah_dibutuhkan']"/>
                                        <span style="color:var(--text-muted);margin-left:4px;" t-esc="material.uom_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="'%.1f' % usage['jumlah_terpenuhi']"/>
                                        <span style="color:var(--text-muted);margin-left:4px;" t-esc="material.uom_id.name"/>
                                    </td>
                                    <td t-esc="'FIFO' if usage['mode_pick'] == 'auto' else 'Manual'"/>
                                    <td style="text-align:right;">
                                        <a t-att-href="'/smi/order/' + str(usage['order_id'])" class="smi-btn smi-btn--secondary smi-btn--sm">Buka Order</a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <div class="empty">Belum ada order yang memakai bahan ini.</div>
                </t>
            </div>
        </div>

        <!-- Denah section: points that hold this material -->
        <div class="smi-card" style="margin-bottom:20px;">
            <div class="smi-card__header">
                <span class="smi-card__title">Lokasi di Denah Gudang</span>
                <a t-att-href="'/smi/stok/denah?material_id=' + str(material.id)"
                   class="smi-btn smi-btn--secondary smi-btn--sm">Lihat Denah Lengkap</a>
            </div>
            <div class="smi-card__body" style="padding:16px;">
                <div class="denah-container" style="position:relative;">
                    <div id="smi_map_data"
                        t-att-data-points="map_points_json"
                        t-att-data-can-manage="'1' if can_manage_points else '0'"
                        style="display:none">
                    </div>

                    <div id="smi_map_root"
                        t-att-data-material-id="material.id"
                        style="width:100%;min-height:520px;">
                    </div>
                </div>
            </div>
        </div>

        <!-- Stock detail (entries) -->
        <div class="smi-card">
            <div class="smi-card__header">
                <span class="smi-card__title">Detail Batch Stok</span>
                <span style="font-size:12px;color:var(--text-muted);">
                    <t t-esc="len(entries)"/> catatan
                </span>
            </div>
            <div class="smi-card__body" style="padding:0;">
                <t t-if="entries">
                    <table class="smi-table">
                        <thead>
                            <tr>
                                <th>Tanggal Masuk</th>
                                <th>Lokasi</th>
                                <th>Jumlah Awal</th>
                                <th>Stok Tersedia</th>
                                <th>Status</th>
                                <th>Dicatat Oleh</th>
                                <t t-if="can_manage_points">
                                    <th>Ubah Lokasi</th>
                                </t>
                            </tr>

                                <t t-call="inventory_smi.warehouse_map_script"/>
                        </thead>
                        <tbody>
                            <t t-foreach="entries" t-as="entry">
                                <tr>
                                    <td style="color:var(--text-muted);font-size:13px;">
                                        <t t-if="entry.tanggal_masuk">
                                            <t t-esc="entry.tanggal_masuk.strftime('%d %b %Y %H:%M')"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td t-esc="entry.inventory_point_id.name or '—'"/>
                                    <td>
                                        <t t-esc="'%.1f' % entry.jumlah_awal"/>
                                    </td>
                                    <td>
                                        <t t-esc="'%.1f' % entry.jumlah_tersisa"/>
                                    </td>
                                    <td>
                                        <t t-if="entry.state == 'tersedia'">
                                            <span class="smi-badge smi-badge--done">Tersedia</span>
                                        </t>
                                        <t t-elif="entry.state == 'habis'">
                                            <span class="smi-badge smi-badge--cancelled">Habis</span>
                                        </t>
                                        <t t-else="">
                                            <span class="smi-badge smi-badge--draft" t-esc="entry.state"/>
                                        </t>
                                    </td>
                                    <td style="color:var(--text-muted);" t-esc="entry.user_id.name or '—'"/>
                                    <t t-if="can_manage_points">
                                        <td>
                                            <form method="post" t-att-action="'/smi/stok/entry/' + str(entry.id) + '/lokasi'" style="display:flex;gap:8px;align-items:center;">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <select name="inventory_point_id" class="smi-form-select" style="min-width:180px;">
                                                    <t t-foreach="inventory_points" t-as="point">
                                                        <option t-att-value="point.id" t-att-selected="'selected' if entry.inventory_point_id and entry.inventory_point_id.id == point.id else None">
                                                            <t t-esc="point.name"/>
                                                        </option>
                                                    </t>
                                                </select>
                                                <button type="submit" class="smi-btn smi-btn--secondary smi-btn--sm">Simpan</button>
                                            </form>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <div class="empty">Belum ada transaksi stok untuk bahan ini.</div>
                </t>
            </div>
        </div>

    </t>
</template>

</data>
</odoo>
