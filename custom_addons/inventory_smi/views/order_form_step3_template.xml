<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="order_form_step3_page" name="SMI Order Form Step 3">
    <t t-call="inventory_smi.layout">
        <t t-set="page_title">Tambah Order — Konfirmasi</t>

        <!-- Step indicator -->
        <div style="display:flex;gap:0;margin-bottom:24px;align-items:center;">
            <div style="display:flex;align-items:center;gap:8px;">
                <div style="width:28px;height:28px;border-radius:50%;background:var(--success); color:#fff;display:flex;align-items:center;justify-content:center;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
                <span style="font-size:13px;color:var(--text-muted);">Info Pesanan</span>
            </div>
            <div style="flex:1;height:2px;background:var(--success);margin:0 12px;"/>
            <div style="display:flex;align-items:center;gap:8px;">
                <div style="width:28px;height:28px;border-radius:50%;background:var(--success); color:#fff;display:flex;align-items:center;justify-content:center;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
                <span style="font-size:13px;color:var(--text-muted);">Pilih Bahan</span>
            </div>
            <div style="flex:1;height:2px;background:var(--primary);margin:0 12px;"/>
            <div style="display:flex;align-items:center;gap:8px;">
                <div style="width:28px;height:28px;border-radius:50%;background:var(--primary);
                            color:#fff;display:flex;align-items:center;justify-content:center;
                            font-size:13px;font-weight:600;">3</div>
                <span style="font-size:13px;font-weight:600;color:var(--primary);">Konfirmasi</span>
            </div>
        </div>

        <t t-if="error">
            <div style="background:#FEF2F2;border:1px solid #FECACA;color:#991B1B;
                        border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:14px;">
                <t t-esc="error"/>
            </div>
        </t>

        <!-- Ringkasan order summary -->
        <div class="smi-card" style="margin-bottom:16px;">
            <div class="smi-card__header">
                <span class="smi-card__title">Ringkasan Pesanan</span>
                <t t-if="all_sufficient">
                    <span class="smi-badge smi-badge--done">Semua Stok Cukup</span>
                </t>
                <t t-else="">
                    <span class="smi-badge smi-badge--warning">Ada Stok Tidak Cukup</span>
                </t>
            </div>
            <div class="smi-card__body" style="padding:20px;">
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px;">
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Nama Pesanan</div>
                        <div style="font-size:15px;font-weight:600;" t-esc="order.name"/>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">No. SPK</div>
                        <div style="font-size:14px;"><t t-esc="order.no_spk or '-'"/></div>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Tanggal</div>
                        <div style="font-size:14px;" t-esc="order.tanggal"/>
                    </div>
                </div>

                <!-- Order lines summary -->
                <t t-if="order.order_line_ids">
                    <table class="smi-table">
                        <thead>
                            <tr>
                                <th>Bahan</th>
                                <th>Dibutuhkan</th>
                                <th>Stok Tersedia</th>
                                <th>Mode</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="order.order_line_ids" t-as="line">
                                <tr>
                                    <td style="font-weight:500;" t-esc="line.material_id.name"/>
                                    <td>
                                        <t t-esc="'%.1f' % line.jumlah_dibutuhkan"/>
                                        <span style="color:var(--text-muted);font-size:12px;margin-left:4px;"
                                              t-esc="line.material_id.uom_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="'%.1f' % line.material_id.total_stok"/>
                                        <span style="color:var(--text-muted);font-size:12px;margin-left:4px;"
                                              t-esc="line.material_id.uom_id.name"/>
                                    </td>
                                    <td>
                                        <t t-if="line.mode_pick == 'auto'">
                                            <span class="smi-badge smi-badge--confirmed">Otomatis (FIFO)</span>
                                        </t>
                                        <t t-else="">
                                            <span class="smi-badge smi-badge--draft">Manual</span>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="line.is_sufficient">
                                            <span class="smi-badge smi-badge--done">Cukup</span>
                                        </t>
                                        <t t-else="">
                                            <span class="smi-badge smi-badge--cancelled">Tidak Cukup</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <div class="empty">Tidak ada bahan yang dipilih.</div>
                </t>
            </div>
        </div>

        <!-- Insufficient stock warning -->
        <t t-if="not all_sufficient">
            <div style="background:#FFFBEB;border:1px solid #FDE68A;color:#92400E;
                        border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:14px;">
                ⚠️ Ada bahan dengan stok tidak cukup. Order akan disimpan sebagai
                <strong>Draft</strong> dan tidak dapat dikonfirmasi. Tambahkan stok terlebih dahulu.
            </div>
        </t>

        <!-- Action buttons -->
        <div style="display:flex;gap:8px;">
                                <form method="post"
                  t-att-action="'/smi/order/tambah/step3?order_id=' + str(order.id)"
                  style="display:inline;">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="action" value="back"/>
                <button type="submit" class="smi-btn smi-btn--secondary">← Kembali</button>
            </form>

            <t t-if="all_sufficient and order.order_line_ids">
                <form method="post"
                      t-att-action="'/smi/order/tambah/step3?order_id=' + str(order.id)"
                      style="display:inline;">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="action" value="confirm"/>
                    <button type="submit" class="smi-btn smi-btn--primary">
                        Konfirmasi Order
                    </button>
                </form>
            </t>
            <t t-else="">
                <a t-att-href="'/smi/order/' + str(order.id)"
                   class="smi-btn smi-btn--secondary">Simpan sebagai Draft</a>
            </t>
        </div>

    </t>
</template>

</data>
</odoo>
