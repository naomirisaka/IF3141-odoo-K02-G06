<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="pengguna_page" name="SMI Pengguna Page">
    <t t-call="inventory_smi.layout">
        <t t-set="page_title">Manajemen Pengguna</t>

        <!-- Toolbar -->
        <div class="smi-toolbar" style="margin-bottom:16px;">
            <form method="get" action="/smi/pengguna"
                  style="display:flex;gap:8px;align-items:center;flex:1;">
                <input type="text" name="search" class="smi-search"
                       placeholder="Cari nama pengguna..."
                       t-att-value="search"/>
                <button type="submit" class="smi-btn smi-btn--secondary smi-btn--sm">Cari</button>
                <t t-if="search">
                    <a href="/smi/pengguna" class="smi-btn smi-btn--secondary smi-btn--sm">Reset</a>
                </t>
            </form>
            <div style="font-size:13px;color:var(--smi-text-muted);align-self:center;">
                <t t-esc="len(users_data)"/> pengguna
            </div>
        </div>

        <!-- Users table -->
        <div class="smi-card">
            <div class="smi-card__header">
                <span class="smi-card__title">Daftar Pengguna</span>
            </div>
            <div class="smi-card__body" style="padding:0;">
                <t t-if="users_data">
                    <div class="smi-table-wrapper">
                        <table class="smi-table">
                            <thead>
                                <tr>
                                    <th>Nama</th>
                                    <th>Login</th>
                                    <th>Password</th>
                                    <th>Jabatan / Role</th>
                                    <th>Status</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="users_data" t-as="ud">
                                    <tr>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:8px;">
                                                <div class="smi-avatar"
                                                    t-att-style="'background:' + (['#3B82F6','#10B981','#F59E0B','#EF4444','#8B5CF6'][ud['user'].id % 5]) + ';'">
                                                <t t-esc="(ud['user'].name or 'U')[0].upper()"/>
                                            </div>
                                            <span style="font-weight:500;"
                                                  t-esc="ud['user'].name"/>
                                        </div>
                                    </td>
                                    <td style="color:var(--smi-text-muted);"
                                        t-esc="ud['user'].login"/>
                                    <td>
                                        <t t-if="ud.get('password_missing')">
                                            <span style="font-size:12px;color:var(--smi-text-muted);">Tidak tersedia</span>
                                        </t>
                                        <t t-else="">
                                            <div style="display:flex;align-items:center;gap:8px;">
                                                <span class="smi-pwd-masked" t-att-data-pwd="ud['password']">
                                                    ••••••
                                                </span>
                                                <span class="smi-pwd-visible" style="display:none;" t-att-data-pwd="ud['password']">
                                                    <t t-esc="ud['password']"/>
                                                </span>
                                                <button type="button"
                                                        class="smi-btn--icon smi-pwd-toggle"
                                                        title="Tampilkan/Sembunyikan password"
                                                        style="padding:4px;border:none;background:none;cursor:pointer;color:var(--smi-text-muted);">
                                                    <svg class="smi-eye-closed" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                                    </svg>
                                                    <svg class="smi-eye-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                                        <circle cx="12" cy="12" r="3"/>
                                                    </svg>
                                                </button>
                                            </div>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="ud['role'] == 'Admin'">
                                            <span class="smi-badge smi-badge--confirmed">Admin</span>
                                        </t>
                                        <t t-elif="ud['role'] == 'Kepala Produksi'">
                                            <span class="smi-badge smi-badge--done">Kepala Produksi</span>
                                        </t>
                                        <t t-elif="ud['role'] == 'Staf Produksi'">
                                            <span class="smi-badge smi-badge--draft">Staf Produksi</span>
                                        </t>
                                        <t t-elif="ud['role'] == 'Direktur'">
                                            <span class="smi-badge smi-badge--warning">Direktur</span>
                                        </t>
                                        <t t-else="">
                                            <span class="smi-badge smi-badge--draft">
                                                <t t-esc="ud['role']"/>
                                            </span>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="ud['user'].active">
                                            <span class="smi-badge smi-badge--done">Aktif</span>
                                        </t>
                                        <t t-else="">
                                            <span class="smi-badge smi-badge--cancelled">Nonaktif</span>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="ud['user'].id != request.env.uid">
                                            <form method="POST" action="/smi/pengguna/change_role"
                                                  style="display:flex;align-items:center;gap:6px;">
                                                <input type="hidden" name="user_id" t-att-value="ud['user'].id"/>
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <select name="new_role" class="smi-select" style="font-size:12px;padding:4px 8px;">
                                                    <t t-foreach="role_choices" t-as="rc">
                                                        <option t-att-value="rc"
                                                                t-att-selected="'selected' if rc == ud['role'] else None">
                                                            <t t-esc="rc"/>
                                                        </option>
                                                    </t>
                                                </select>
                                                <button type="submit" class="smi-btn smi-btn--primary smi-btn--sm" title="Ubah Role">
                                                    Ubah
                                                </button>
                                            </form>
                                        </t>
                                        <t t-else="">
                                            <span style="font-size:12px;color:var(--smi-text-muted);">—</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
            <t t-else="">
                <div class="smi-empty">
                    <span class="smi-empty__title">Tidak ada pengguna ditemukan.</span>
                </div>
            </t>
        </div>
    </div>

    <!-- Password eye toggle script -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.smi-pwd-toggle').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var row = btn.closest('tr');
                    var masked = row.querySelector('.smi-pwd-masked');
                    var visible = row.querySelector('.smi-pwd-visible');
                    var eyeClosed = btn.querySelector('.smi-eye-closed');
                    var eyeOpen = btn.querySelector('.smi-eye-open');
                    if (visible.style.display === 'none') {
                        visible.style.display = '';
                        masked.style.display = 'none';
                        eyeClosed.style.display = 'none';
                        eyeOpen.style.display = '';
                    } else {
                        visible.style.display = 'none';
                        masked.style.display = '';
                        eyeClosed.style.display = '';
                        eyeOpen.style.display = 'none';
                    }
                });
            });
        });
    </script>

    </t>
</template>

</data>
</odoo>