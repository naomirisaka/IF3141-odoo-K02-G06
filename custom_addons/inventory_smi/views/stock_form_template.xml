<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="stock_form_page" name="SMI Tambah Stok">
    <t t-call="inventory_smi.layout">
        <t t-set="page_title">Tambah Stok</t>
        <t t-set="active_menu">stok</t>

        <!-- Back link -->
        <a href="/smi/stok" class="back-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Kembali ke Daftar Stok
        </a>

        <div class="smi-card" style="max-width:700px;">
            <div class="smi-card__header">
                <span class="smi-card__title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         style="vertical-align:middle;margin-right:6px;">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                        <line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                    Form Tambah Stok
                </span>
            </div>

            <div class="smi-card__body">

                <!-- Error banner -->
                <t t-if="error">
                    <div class="smi-alert smi-alert--danger" t-esc="error"/>
                </t>

                <form method="post" action="/smi/stok/tambah">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Nama Bahan -->
                    <div class="form-group">
                        <label class="form-label" for="material_id">
                            Nama Bahan <span style="color:var(--danger);">*</span>
                        </label>
                        <select name="material_id" class="smi-form-select" required="required" id="material_id">
                            <option value="">-- Pilih Bahan --</option>
                            <t t-foreach="materials" t-as="mat">
                                <option t-att-value="mat.id"
                                        t-att-selected="'selected' if post.get('material_id') == str(mat.id) else None"
                                        t-esc="mat.name"/>
                            </t>
                        </select>
                    </div>

                    <!-- Titik Inventori -->
                    <div class="form-group">
                        <label class="form-label" for="inventory_point_id">
                            Titik Inventori <span style="color:var(--danger);">*</span>
                        </label>
                        <div class="input-group">
                            <select name="inventory_point_id" class="smi-form-select" required="required" id="inventory_point_id">
                                <option value="">-- Pilih Lokasi --</option>
                                <t t-foreach="points" t-as="pt">
                                    <option t-att-value="pt.id"
                                            t-att-selected="'selected' if post.get('inventory_point_id') == str(pt.id) else None"
                                            t-esc="pt.name"/>
                                </t>
                            </select>
                                <button type="button" class="smi-btn smi-btn--secondary"
                                    onclick="document.getElementById('map-modal').classList.add('open')">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                                </svg>
                                Pilih dari Denah
                            </button>
                        </div>
                    </div>

                    <!-- Jumlah Masuk -->
                    <div class="form-group">
                        <label class="form-label" for="jumlah_awal">
                            Jumlah Masuk <span style="color:var(--danger);">*</span>
                        </label>
                           <input type="number" name="jumlah_awal" id="jumlah_awal"
                               class="smi-input" min="0.01" step="0.01"
                               required="required" placeholder="Masukkan jumlah stok"
                               t-att-value="post.get('jumlah_awal', '')"/>
                    </div>

                    <!-- Tanggal Masuk -->
                    <div class="form-group">
                        <label class="form-label" for="tanggal_masuk">Tanggal Masuk</label>
                           <input type="datetime-local" name="tanggal_masuk" id="tanggal_masuk"
                               class="smi-input"
                               t-att-value="post.get('tanggal_masuk', '')"/>
                        <span class="form-hint">Kosongkan untuk menggunakan waktu sekarang.</span>
                    </div>

                    <!-- Catatan -->
                    <div class="form-group">
                        <label class="form-label" for="catatan">Catatan</label>
                        <textarea name="catatan" id="catatan" class="smi-textarea"
                                  rows="3" placeholder="Catatan tambahan (opsional)">
                            <t t-esc="post.get('catatan', '')"/>
                        </textarea>
                    </div>

                    <div style="display:flex;gap:10px;margin-top:24px;padding-top:20px;border-top:1px solid var(--border);">
                        <button type="submit" class="smi-btn smi-btn--primary">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Simpan Stok
                        </button>
                        <a href="/smi/stok" class="smi-btn smi-btn--secondary">Batal</a>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===== MAP MODAL ===== -->
        <div id="map-modal" class="smi-modal-overlay">
            <div class="smi-modal">
                <div class="smi-modal__header">
                    <span class="smi-modal__title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             style="vertical-align:middle;margin-right:6px;">
                            <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                        </svg>
                        Pilih Titik dari Denah
                    </span>
                    <button type="button" class="smi-btn smi-btn--secondary smi-btn--sm"
                            onclick="document.getElementById('map-modal').classList.remove('open')">
                        ✕ Tutup
                    </button>
                </div>
                <div class="smi-modal__body">
                    <div style="position:relative;border-radius:10px;overflow:hidden;border:1px solid var(--border);">
                        <div id="smi_map_root"
                            style="width:100%;min-height:520px;">
                        </div>
                        <t t-foreach="points" t-as="pt">
                            <div style="position:absolute;cursor:pointer;width:18px;height:18px;
                                        border-radius:50%;background:#3B82F6;border:2px solid #fff;
                                        box-shadow:0 2px 6px rgba(0,0,0,0.25);
                                        transform:translate(-50%,-50%);transition:transform 0.15s,background 0.15s;"
                                 t-att-title="pt.name"
                                 t-att-data-id="pt.id"
                                 t-att-data-name="pt.name"
                                 t-att-style="'position:absolute;cursor:pointer;width:18px;height:18px;border-radius:50%;background:#3B82F6;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,0.25);transform:translate(-50%,-50%);transition:transform 0.15s;left:' + str(pt.koordinat_x) + '%;top:' + str(pt.koordinat_y) + '%;'"
                                 onmouseenter="this.style.transform='translate(-50%,-50%) scale(1.3)'"
                                 onmouseleave="this.style.transform='translate(-50%,-50%) scale(1)'"
                                 onclick="selectInventoryPoint(this.dataset.id, this.dataset.name)">
                            </div>
                        </t>
                    </div>
                    <p style="margin-top:12px;font-size:13px;color:var(--text-muted);">
                        Klik titik biru pada denah untuk memilih lokasi inventori.
                    </p>
                </div>
            </div>
        </div>

        <script type="text/javascript">
        function selectInventoryPoint(id, name) {
            var sel = document.getElementById('inventory_point_id');
            for (var i = 0; i &lt; sel.options.length; i++) {
                if (sel.options[i].value == id) {
                    sel.selectedIndex = i;
                    // Visual feedback
                    sel.style.borderColor = '#10B981';
                    sel.style.boxShadow = '0 0 0 3px rgba(16,185,129,0.15)';
                    setTimeout(function() {
                        sel.style.borderColor = '';
                        sel.style.boxShadow = '';
                    }, 2000);
                    break;
                }
            }
            document.getElementById('map-modal').classList.remove('open');
        }

        // Close modal when clicking backdrop
        document.getElementById('map-modal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('open');
        });
        </script>

    </t>
</template>

</data>
</odoo>
