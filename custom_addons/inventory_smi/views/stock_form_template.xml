<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="stock_form_page" name="SMI Tambah Stok">
    <t t-call="inventory_smi.layout">
        <t t-set="page_title">Tambah Stok</t>
        <t t-set="active_menu">stok</t>

        <!-- Back link -->
        <a href="/smi/stok" class="back-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Kembali ke Daftar Stok
        </a>

        <div class="smi-card" style="max-width:700px;">
            <div class="smi-card__header">
                <span class="smi-card__title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         style="vertical-align:middle;margin-right:6px;">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                        <line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                    Form Tambah Stok
                </span>
            </div>

            <div class="smi-card__body">

                <!-- Error banner -->
                <t t-if="error">
                    <div class="smi-alert smi-alert--danger" t-esc="error"/>
                </t>

                <form method="post" action="/smi/stok/tambah">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Nama Bahan — dropdown dengan opsi tambah baru -->
                    <div class="form-group">
                        <label class="form-label" for="smi_mat_sel">
                            Nama Bahan <span style="color:var(--danger);">*</span>
                        </label>
                        <select name="material_id" id="smi_mat_sel" class="smi-form-select"
                                required="required" onchange="smiMatChange(this)">
                            <option value="">-- Pilih Bahan --</option>
                            <t t-foreach="materials" t-as="mat">
                                <option t-att-value="mat.id"
                                        t-att-selected="'selected' if post.get('material_id') == str(mat.id) else None"
                                        t-esc="mat.name"/>
                            </t>
                            <option disabled="disabled" style="color:#CBD5E1;">&#8212;&#8212;&#8212;&#8212;&#8212;&#8212;&#8212;</option>
                            <option value="__new__"
                                    t-att-selected="'selected' if post.get('material_id') == '__new__' else None"
                                    style="color:#2563EB;font-weight:600;">
                                &#43; Tambah Bahan Baru
                            </option>
                        </select>
                    </div>

                    <!-- Field tambahan: hanya muncul saat "+ Tambah Bahan Baru" dipilih -->
                    <div id="smi_new_mat_fields"
                         t-att-style="'display:block;background:#F8FAFC;border:1.5px solid #E2E8F0;border-radius:8px;padding:16px 16px 4px;margin-top:-12px;margin-bottom:20px;' if post.get('material_id') == '__new__' else 'display:none;'">
                        <p style="font-size:12px;font-weight:600;color:#64748B;margin-bottom:12px;text-transform:uppercase;letter-spacing:.04em;">
                            Detail Bahan Baru
                        </p>
                        <div class="form-group">
                            <label class="form-label" for="smi_new_name">Nama Bahan Baru <span style="color:var(--danger);">*</span></label>
                            <input type="text" name="new_material_name" id="smi_new_name"
                                   class="smi-input" placeholder="Masukkan nama bahan baru"
                                   t-att-value="post.get('new_material_name', '')"
                                   t-att-disabled="None if post.get('material_id') == '__new__' else 'disabled'"/>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="smi_new_uom">Satuan <span style="color:var(--danger);">*</span></label>
                            <select name="new_uom_id" id="smi_new_uom" class="smi-form-select"
                                    t-att-disabled="None if post.get('material_id') == '__new__' else 'disabled'">
                                <option value="">-- Pilih Satuan --</option>
                                <t t-foreach="uoms" t-as="uom">
                                    <option t-att-value="uom.id"
                                            t-att-selected="'selected' if post.get('new_uom_id') == str(uom.id) else None"
                                            t-esc="uom.name"/>
                                </t>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="smi_new_cat">Kategori <span style="color:var(--danger);">*</span></label>
                            <select name="new_category_id" id="smi_new_cat" class="smi-form-select"
                                    t-att-disabled="None if post.get('material_id') == '__new__' else 'disabled'">
                                <option value="">-- Pilih Kategori --</option>
                                <t t-foreach="categories" t-as="cat">
                                    <option t-att-value="cat.id"
                                            t-att-selected="'selected' if post.get('new_category_id') == str(cat.id) else None"
                                            t-esc="cat.name"/>
                                </t>
                            </select>
                        </div>
                    </div>

                    <!-- Titik Inventori -->
                    <div class="form-group">
                        <label class="form-label" for="inventory_point_id">
                            Titik Inventori <span style="color:var(--danger);">*</span>
                        </label>
                        <div class="input-group">
                            <select name="inventory_point_id" class="smi-form-select" required="required" id="inventory_point_id">
                                <option value="">-- Pilih Lokasi --</option>
                                <t t-foreach="points" t-as="pt">
                                    <option t-att-value="pt.id"
                                            t-att-selected="'selected' if post.get('inventory_point_id') == str(pt.id) else None"
                                            t-esc="pt.name"/>
                                </t>
                            </select>
                                <button type="button" class="smi-btn smi-btn--secondary"
                                    onclick="smiOpenMapModal()" style="border-radius: 8px;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                                </svg>
                                Pilih dari Denah
                            </button>
                        </div>
                    </div>

                    <!-- Jumlah Masuk -->
                    <div class="form-group">
                        <label class="form-label" for="jumlah_awal">
                            Jumlah Masuk <span style="color:var(--danger);">*</span>
                        </label>
                           <input type="number" name="jumlah_awal" id="jumlah_awal"
                               class="smi-input" min="0.01" step="0.01"
                               required="required" placeholder="Masukkan jumlah stok"
                               t-att-value="post.get('jumlah_awal', '')"/>
                    </div>

                    <!-- Tanggal Masuk -->
                    <div class="form-group">
                        <label class="form-label" for="tanggal_masuk">Tanggal Masuk</label>
                           <input type="datetime-local" name="tanggal_masuk" id="tanggal_masuk"
                               class="smi-input"
                               t-att-value="post.get('tanggal_masuk', '')"/>
                        <span class="form-hint">Kosongkan untuk menggunakan waktu sekarang.</span>
                    </div>

                    <!-- Catatan -->
                    <div class="form-group">
                        <label class="form-label" for="catatan">Catatan</label>
                        <textarea name="catatan" id="catatan" class="smi-textarea"
                                  rows="3" placeholder="Catatan tambahan (opsional)">
                            <t t-esc="post.get('catatan', '')"/>
                        </textarea>
                    </div>

                    <div style="display:flex;gap:10px;margin-top:24px;padding-top:20px;border-top:1px solid var(--border);">
                        <button type="submit" class="smi-btn smi-btn--primary">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Simpan Stok
                        </button>
                        <a href="/smi/stok" class="smi-btn smi-btn--secondary">Batal</a>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===== MAP MODAL ===== -->
        <div id="map-modal" class="smi-modal-overlay">
            <div class="smi-modal smi-modal--lg">
                <div class="smi-modal__header">
                    <span class="smi-modal__title">Pilih Titik dari Denah</span>
                    <button type="button" class="smi-btn--icon" onclick="document.getElementById('map-modal').classList.remove('open')">&#10005;</button>
                </div>
                <div class="smi-modal__body">
                    <p style="font-size:13px;color:#64748B;margin-bottom:10px;">Klik titik berwarna pada denah untuk memilih lokasi.</p>
                    <!-- SVG denah plain — tidak pakai OWL, click handler langsung di DOM -->
                    <svg id="smi_pick_svg" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg"
                         style="width:100%;height:340px;border:1px solid #E2E8F0;border-radius:8px;background:#F8FAFC;display:block;">
                        <!-- Latar -->
                        <rect x="2" y="2" width="796" height="496" rx="10" ry="10" fill="#F8FAFC" stroke="#CBD5E1" stroke-width="3"/>
                        <text x="400" y="22" font-family="Inter,system-ui,sans-serif" font-size="13" fill="#64748B" text-anchor="middle" font-weight="600">CV Dunia Offset Printing — Denah Lantai Produksi</text>
                        <!-- Mesin -->
                        <rect x="40"  y="50"  width="160" height="90" fill="#E2E8F0" stroke="#94A3B8" stroke-width="1.5" rx="6"/>
                        <text x="120" y="91"  font-family="Inter,system-ui,sans-serif" font-size="12" fill="#475569" text-anchor="middle" font-weight="600">Mesin Cetak 1</text>
                        <text x="120" y="110" font-family="Inter,system-ui,sans-serif" font-size="10" fill="#94A3B8" text-anchor="middle">Offset Printing</text>
                        <rect x="240" y="50"  width="160" height="90" fill="#E2E8F0" stroke="#94A3B8" stroke-width="1.5" rx="6"/>
                        <text x="320" y="91"  font-family="Inter,system-ui,sans-serif" font-size="12" fill="#475569" text-anchor="middle" font-weight="600">Mesin Cetak 2</text>
                        <text x="320" y="110" font-family="Inter,system-ui,sans-serif" font-size="10" fill="#94A3B8" text-anchor="middle">Offset Printing</text>
                        <rect x="40"  y="190" width="150" height="80" fill="#E2E8F0" stroke="#94A3B8" stroke-width="1.5" rx="6"/>
                        <text x="115" y="226" font-family="Inter,system-ui,sans-serif" font-size="12" fill="#475569" text-anchor="middle" font-weight="600">Mesin Laminasi</text>
                        <text x="115" y="244" font-family="Inter,system-ui,sans-serif" font-size="10" fill="#94A3B8" text-anchor="middle">Hot / Cold</text>
                        <rect x="40"  y="330" width="150" height="80" fill="#E2E8F0" stroke="#94A3B8" stroke-width="1.5" rx="6"/>
                        <text x="115" y="366" font-family="Inter,system-ui,sans-serif" font-size="12" fill="#475569" text-anchor="middle" font-weight="600">Mesin Pond</text>
                        <text x="115" y="384" font-family="Inter,system-ui,sans-serif" font-size="10" fill="#94A3B8" text-anchor="middle">Die Cutting</text>
                        <rect x="240" y="330" width="150" height="80" fill="#E2E8F0" stroke="#94A3B8" stroke-width="1.5" rx="6"/>
                        <text x="315" y="366" font-family="Inter,system-ui,sans-serif" font-size="12" fill="#475569" text-anchor="middle" font-weight="600">Mesin Foil</text>
                        <text x="315" y="384" font-family="Inter,system-ui,sans-serif" font-size="10" fill="#94A3B8" text-anchor="middle">Hot Stamping</text>
                        <rect x="600" y="40"  width="160" height="220" fill="#EFF6FF" stroke="#93C5FD" stroke-width="1.5" rx="6"/>
                        <text x="680" y="138" font-family="Inter,system-ui,sans-serif" font-size="12" fill="#3B82F6" text-anchor="middle" font-weight="600">Gudang Bahan</text>
                        <text x="680" y="156" font-family="Inter,system-ui,sans-serif" font-size="10" fill="#93C5FD" text-anchor="middle">Area Penyimpanan</text>
                        <rect x="450" y="330" width="160" height="80" fill="#E2E8F0" stroke="#94A3B8" stroke-width="1.5" rx="6"/>
                        <text x="530" y="366" font-family="Inter,system-ui,sans-serif" font-size="12" fill="#475569" text-anchor="middle" font-weight="600">Area Finishing</text>
                        <text x="530" y="384" font-family="Inter,system-ui,sans-serif" font-size="10" fill="#94A3B8" text-anchor="middle">Packaging</text>
                        <!-- Walkways -->
                        <line x1="215" y1="50"  x2="215" y2="450" stroke="#E2E8F0" stroke-width="2" stroke-dasharray="6,4"/>
                        <line x1="430" y1="50"  x2="430" y2="450" stroke="#E2E8F0" stroke-width="2" stroke-dasharray="6,4"/>
                        <line x1="40"  y1="160" x2="590" y2="160" stroke="#E2E8F0" stroke-width="2" stroke-dasharray="6,4"/>
                        <line x1="40"  y1="295" x2="765" y2="295" stroke="#E2E8F0" stroke-width="2" stroke-dasharray="6,4"/>
                        <!-- Titik inventori dirender oleh JS di sini -->
                        <g id="smi_pick_points"/>
                    </svg>
                    <!-- Legend -->
                    <div style="display:flex;gap:16px;margin-top:8px;font-size:12px;color:#64748B;">
                        <span><svg width="10" height="10"><circle cx="5" cy="5" r="5" fill="#10B981"/></svg> Aman</span>
                        <span><svg width="10" height="10"><circle cx="5" cy="5" r="5" fill="#F59E0B"/></svg> Stok sedikit</span>
                        <span><svg width="10" height="10"><circle cx="5" cy="5" r="5" fill="#94A3B8"/></svg> Kosong</span>
                    </div>
                    <div style="margin-top:12px;text-align:right;">
                        <button type="button" class="smi-btn smi-btn--secondary smi-btn--sm"
                                onclick="document.getElementById('map-modal').classList.remove('open')">Tutup</button>
                    </div>
                </div>
            </div>
        </div>

        <script type="text/javascript">
        //<![CDATA[
        function smiMatChange(sel) {
            var extra   = document.getElementById('smi_new_mat_fields');
            var nameInp = document.getElementById('smi_new_name');
            var uomSel  = document.getElementById('smi_new_uom');
            var catSel  = document.getElementById('smi_new_cat');
            var isNew   = sel.value === '__new__';
            extra.style.display = isNew ? 'block' : 'none';
            nameInp.disabled    = !isNew;
            uomSel.disabled     = !isNew;
            catSel.disabled     = !isNew;
            if (isNew) { nameInp.focus(); }
        }

        function smiPickPointOnMap(id, name) {
            var sel = document.getElementById('inventory_point_id');
            for (var i = 0; i < sel.options.length; i++) {
                if (sel.options[i].value == String(id)) {
                    sel.selectedIndex = i;
                    sel.style.borderColor = '#10B981';
                    sel.style.boxShadow = '0 0 0 3px rgba(16,185,129,0.15)';
                    setTimeout(function() { sel.style.borderColor = ''; sel.style.boxShadow = ''; }, 2000);
                    break;
                }
            }
            document.getElementById('map-modal').classList.remove('open');
        }

        function smiOpenMapModal() {
            document.getElementById('map-modal').classList.add('open');
            var g = document.getElementById('smi_pick_points');
            g.innerHTML = '<text x="400" y="260" text-anchor="middle" font-size="14" fill="#94A3B8">Memuat titik...</text>';

            fetch('/smi/api/inventory_points', { credentials: 'same-origin' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    g.innerHTML = '';
                    var pts = data.points || [];
                    if (pts.length === 0) {
                        g.innerHTML = '<text x="400" y="260" text-anchor="middle" font-size="14" fill="#94A3B8">Belum ada titik inventori.</text>';
                        return;
                    }
                    var NS = 'http://www.w3.org/2000/svg';
                    pts.forEach(function(pt) {
                        var cx = (pt.x / 100) * 800;
                        var cy = (pt.y / 100) * 500;
                        var hasMat = pt.materials && pt.materials.length > 0;
                        var hasLow = hasMat && pt.materials.some(function(m) { return m.is_low_stock; });
                        var color  = !hasMat ? '#94A3B8' : (hasLow ? '#F59E0B' : '#10B981');

                        var grp = document.createElementNS(NS, 'g');
                        grp.style.cursor = 'pointer';

                        var circle = document.createElementNS(NS, 'circle');
                        circle.setAttribute('cx', cx);
                        circle.setAttribute('cy', cy);
                        circle.setAttribute('r',  '14');
                        circle.setAttribute('fill', color);
                        circle.setAttribute('stroke', 'white');
                        circle.setAttribute('stroke-width', '2.5');

                        var label = document.createElementNS(NS, 'text');
                        label.setAttribute('x', cx);
                        label.setAttribute('y', cy + 4);
                        label.setAttribute('text-anchor', 'middle');
                        label.setAttribute('font-size', '9');
                        label.setAttribute('font-weight', '600');
                        label.setAttribute('fill', 'white');
                        label.setAttribute('pointer-events', 'none');
                        label.setAttribute('font-family', 'Inter,system-ui,sans-serif');
                        label.textContent = pt.name.substring(0, 5);

                        grp.addEventListener('mouseenter', function() { circle.setAttribute('r', '17'); });
                        grp.addEventListener('mouseleave', function() { circle.setAttribute('r', '14'); });
                        grp.addEventListener('click', function(e) {
                            e.stopPropagation();
                            smiPickPointOnMap(pt.id, pt.name);
                        });

                        grp.appendChild(circle);
                        grp.appendChild(label);
                        g.appendChild(grp);
                    });
                })
                .catch(function() {
                    g.innerHTML = '<text x="400" y="260" text-anchor="middle" font-size="14" fill="#EF4444">Gagal memuat titik.</text>';
                });
        }

        document.getElementById('map-modal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('open');
        });
        //]]>
        </script>

    </t>
</template>

</data>
</odoo>
