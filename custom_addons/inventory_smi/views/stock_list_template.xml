<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="stock_list_page" name="SMI Stock List">
    <t t-call="inventory_smi.layout">
        <t t-set="page_title">Stok Bahan Baku</t>

        <!-- Toolbar -->
        <div class="smi-toolbar">
            <form method="get" action="/smi/stok" style="display:flex;gap:8px;align-items:center;flex:1;">
                <input type="text" name="search" class="smi-search"
                       placeholder="Cari nama bahan..."
                       t-att-value="search"/>
                <select name="sort" class="smi-form-select" style="width:180px;">
                    <option value="name" t-att-selected="'selected' if sort == 'name' else None">Nama A–Z</option>
                    <option value="stok_asc" t-att-selected="'selected' if sort == 'stok_asc' else None">Stok Terendah</option>
                    <option value="stok_desc" t-att-selected="'selected' if sort == 'stok_desc' else None">Stok Tertinggi</option>
                </select>
                <button type="submit" class="smi-btn smi-btn--secondary smi-btn--sm">Cari</button>
            </form>
            <div style="display:flex;gap:8px;">
                <t t-if="not is_direktur">
                    <a href="/smi/stok/tambah" class="smi-btn smi-btn--primary smi-btn--sm">+ Tambah Stok</a>
                </t>
                <a href="/smi/stok/denah" class="smi-btn smi-btn--secondary smi-btn--sm">Lihat Denah</a>
            </div>
        </div>

        <!-- Table Card -->
        <div class="smi-card">
            <div class="smi-card__header">
                <span class="smi-card__title">Daftar Bahan Baku</span>
                <span style="font-size:12px;color:var(--text-muted);">
                    <t t-esc="len(materials)"/> bahan aktif
                </span>
            </div>
            <div class="smi-card__body" style="padding:0;">
                <t t-if="materials">
                    <table class="smi-table">
                        <thead>
                            <tr>
                                <th>Nama Bahan</th>
                                <th>Kategori</th>
                                <th>Total Stok</th>
                                <th>Satuan</th>
                                <th>Stok Minimum</th>
                                <th>Status</th>
                                <th style="width:120px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="materials" t-as="mat">
                                <tr style="cursor:pointer;"
                                    t-att-data-href="'/smi/stok/' + str(mat.id)"
                                    onclick="if(event.target.classList.contains('smi-skip-nav')){return;} window.location=this.dataset.href">
                                    <td style="font-weight:500;" t-esc="mat.name"/>
                                    <td style="color:var(--text-muted);" t-esc="mat.category_id.name"/>
                                    <td>
                                        <span t-esc="'%.1f' % mat.total_stok"/>
                                    </td>
                                    <td style="color:var(--text-muted);" t-esc="mat.uom_id.name"/>
                                    <td t-esc="'%.1f' % (mat.stok_minimum or 0.0)"/>
                                    <td style="align-items:center">
                                        <t t-if="mat.total_stok == 0">
                                            <span class="smi-badge smi-badge--kosong">Kosong</span>
                                        </t>
                                        <t t-elif="mat.is_low_stock">
                                            <span class="smi-badge smi-badge--low-stock">Sisa Sedikit</span>
                                        </t>
                                        <t t-else="">
                                            <span class="smi-badge smi-badge--aman">Aman</span>
                                        </t>
                                    </td>
                                    <td style="display:flex;gap:4px;" onclick="event.stopPropagation()">
                                        <t t-if="can_manage_points">
                                            <button class="smi-btn smi-btn--primary smi-btn--sm smi-skip-nav"
                                                    t-att-data-material-id="mat.id"
                                                    t-att-data-stok-min="'%.1f' % (mat.stok_minimum or 0.0)"
                                                    onclick="window.openStokMinModal(this)">
                                                Edit Min
                                            </button>
                                        </t>
                                        <a t-att-href="'/smi/stok/' + str(mat.id)"
                                           class="smi-btn smi-btn--secondary smi-btn--sm smi-skip-nav">Detail</a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <div class="empty">Tidak ada bahan baku ditemukan.</div>
                </t>
            </div>
        </div>

        <!-- Modal Edit Stok Minimum -->
        <div id="stokMinModalOverlay" class="smi-modal-overlay">
            <div class="smi-modal">
                <div class="smi-modal__header">
                    <h3 class="smi-modal__title" id="stokMinModalTitle">Edit Stok Minimum</h3>
                    <button type="button" class="smi-modal__close" onclick="window.closeStokMinModal()">×</button>
                </div>
                <div class="smi-modal__body">
                    <div style="margin-bottom:16px;">
                        <label class="smi-label">Stok Minimum (unit)</label>
                        <input type="number" id="stokMinInput" class="smi-input" min="0" step="0.1" style="width:100%;"/>
                    </div>
                </div>
                <div class="smi-modal__footer">
                    <button type="button" class="smi-btn smi-btn--secondary" onclick="window.closeStokMinModal()">Batal</button>
                    <button type="button" class="smi-btn smi-btn--primary" onclick="window.saveStokMin()">Simpan</button>
                </div>
            </div>
        </div>

        <script type="text/javascript">
        <![CDATA[
        window.currentMaterialId = null;

        window.openStokMinModal = function(button) {
            window.currentMaterialId = parseInt(button.dataset.materialId);
            var materialName = button.closest('tr').querySelector('td').textContent;
            var currentValue = parseFloat(button.dataset.stokMin) || 0;
            
            document.getElementById('stokMinModalTitle').textContent = 'Edit Stok Minimum - ' + materialName;
            document.getElementById('stokMinInput').value = currentValue;
            document.getElementById('stokMinModalOverlay').classList.add('open');
            document.getElementById('stokMinInput').focus();
        };

        window.closeStokMinModal = function() {
            document.getElementById('stokMinModalOverlay').classList.remove('open');
            window.currentMaterialId = null;
        };

        window.saveStokMin = function() {
            if (!window.currentMaterialId) return;
            
            var value = parseFloat(document.getElementById('stokMinInput').value) || 0;
            var formData = new FormData();
            formData.append('stok_minimum', value);
            
            fetch('/smi/api/material/' + window.currentMaterialId + '/stok-minimum', {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            })
            .then(function(resp) {
                if (resp.ok) {
                    // Update nilai di tabel tanpa reload
                    var rows = document.querySelectorAll('tbody tr');
                    rows.forEach(function(row) {
                        var btn = row.querySelector('[data-material-id]');
                        if (btn && parseInt(btn.dataset.materialId) === window.currentMaterialId) {
                            row.querySelectorAll('td')[4].textContent = value.toFixed(1);
                            btn.dataset.stokMin = value.toFixed(1);
                        }
                    });
                    window.closeStokMinModal();
                } else {
                    alert('Gagal memperbarui stok minimum');
                }
            })
            .catch(function(err) {
                console.error(err);
                alert('Koneksi gagal');
            });
        };

        // Close modal when clicking outside
        document.addEventListener('click', function(e) {
            var overlay = document.getElementById('stokMinModalOverlay');
            if (e.target === overlay) {
                window.closeStokMinModal();
            }
        });

        // Allow Enter key to save
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && document.getElementById('stokMinModalOverlay').classList.contains('open')) {
                window.saveStokMin();
            }
        });
        ]]>
        </script>

    </t>
</template>

</data>
</odoo>
