<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="stock_list_page" name="SMI Stock List">
    <t t-call="inventory_smi.layout">
        <t t-set="page_title">Stok Bahan Baku</t>

        <!-- Toolbar -->
        <div class="toolbar">
            <form method="get" action="/smi/stok" style="display:flex;gap:8px;align-items:center;flex:1;">
                <input type="text" name="search" class="form-control"
                       placeholder="Cari nama bahan..."
                       t-att-value="search"/>
                <select name="sort" class="form-control" style="width:180px;">
                    <option value="name" t-att-selected="'selected' if sort == 'name' else None">Nama A–Z</option>
                    <option value="stok_asc" t-att-selected="'selected' if sort == 'stok_asc' else None">Stok Terendah</option>
                    <option value="stok_desc" t-att-selected="'selected' if sort == 'stok_desc' else None">Stok Tertinggi</option>
                </select>
                <button type="submit" class="btn btn-secondary btn-sm">Cari</button>
            </form>
            <div style="display:flex;gap:8px;">
                <t t-if="not is_direktur">
                    <a href="/smi/stok/tambah" class="btn btn-primary btn-sm">+ Tambah Stok</a>
                </t>
                <a href="/smi/stok/denah" class="btn btn-secondary btn-sm">Lihat Denah</a>
            </div>
        </div>

        <!-- Table Card -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Daftar Bahan Baku</span>
                <span style="font-size:12px;color:var(--text-muted);">
                    <t t-esc="len(materials)"/> bahan aktif
                </span>
            </div>
            <div class="card-body" style="padding:0;">
                <t t-if="materials">
                    <table class="tbl">
                        <thead>
                            <tr>
                                <th>Nama Bahan</th>
                                <th>Kategori</th>
                                <th>Total Stok</th>
                                <th>Satuan</th>
                                <th>Stok Minimum</th>
                                <th>Status</th>
                                <th style="width:80px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="materials" t-as="mat">
                                <tr style="cursor:pointer;"
                                    t-att-data-href="'/smi/stok/' + str(mat.id)"
                                    onclick="window.location=this.dataset.href">
                                    <td style="font-weight:500;" t-esc="mat.name"/>
                                    <td style="color:var(--text-muted);" t-esc="mat.category_id.name"/>
                                    <td>
                                        <span t-esc="'%.1f' % mat.total_stok"/>
                                    </td>
                                    <td style="color:var(--text-muted);" t-esc="mat.uom_id.name"/>
                                    <td t-esc="'%.1f' % (mat.stok_minimum or 0.0)"/>
                                    <td>
                                        <t t-if="mat.is_low_stock">
                                            <span class="badge badge-danger">Sisa Sedikit</span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge badge-success">Aman</span>
                                        </t>
                                    </td>
                                    <td onclick="event.stopPropagation()">
                                        <a t-att-href="'/smi/stok/' + str(mat.id)"
                                           class="btn btn-secondary btn-sm">Detail</a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <div class="empty">Tidak ada bahan baku ditemukan.</div>
                </t>
            </div>
        </div>

    </t>
</template>

</data>
</odoo>
