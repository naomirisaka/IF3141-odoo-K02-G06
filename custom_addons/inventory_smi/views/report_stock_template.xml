<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="report_stock_template" name="Stock Report">
      <t t-call="web.html_container">
        <t t-set="title">Laporan Stok</t>
        <style>
          @page { size: A4; margin: 20mm; }
          body { font-family: 'DejaVu Sans', Arial, Helvetica, sans-serif; font-size: 12px; color: #222; }
          h1 { font-size: 20px; margin-bottom: 8px; }
          .meta { margin-bottom: 12px; color: #444; }
          table.report { width: 100%; border-collapse: collapse; margin-top: 8px; }
          table.report th, table.report td { border: 1px solid #ddd; padding: 6px 8px; }
          table.report th { background: #f7f7f7; font-weight: 700; font-size: 12px; }
          td.right { text-align: right; }
          .small { font-size: 11px; color: #666; }
          .page-footer { position: fixed; bottom: 10mm; left: 20mm; right: 20mm; font-size: 11px; color: #666; }
        </style>

        <div class="page">
          <h1>Laporan Stok</h1>
          <div class="meta">Periode: <span t-esc="date_from or '-'"/> — <span t-esc="date_to or '-'"/></div>

          <table class="report">
            <thead>
              <tr>
                <th>Tanggal Masuk</th>
                <th>Material</th>
                <th>Titik</th>
                <th class="right">Jumlah Awal</th>
                <th class="right">Jumlah Tersisa</th>
                <th>Status</th>
                <th>Keterangan</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="rows" t-as="r">
                <tr>
                  <td><t t-esc="r['tanggal_masuk']"/></td>
                  <td><t t-esc="r['material']"/></td>
                  <td><t t-esc="r['inventory_point']"/></td>
                  <td class="right"><t t-esc="r['jumlah_awal']"/></td>
                  <td class="right"><t t-esc="r['jumlah_tersisa']"/></td>
                  <td><t t-esc="r['state']"/></td>
                  <td class="small"><t t-esc="r['keterangan']"/></td>
                </tr>
              </t>
            </tbody>
          </table>

          <div class="page-footer">Generated by SMI — Laporan Stok</div>
        </div>
      </t>
    </template>
  </data>
</odoo>
