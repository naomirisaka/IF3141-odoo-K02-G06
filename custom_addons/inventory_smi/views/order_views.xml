<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

  <!-- ======== smi.order ======== -->
  <record id="view_smi_order_tree" model="ir.ui.view">
    <field name="name">smi.order.tree</field>
    <field name="model">smi.order</field>
    <field name="arch" type="xml">
      <tree string="Daftar Order"
            decoration-info="state == 'draft'"
            decoration-success="state == 'selesai'"
            decoration-danger="state == 'dibatalkan'"
            decoration-primary="state == 'dikonfirmasi'">
        <field name="name"/>
        <field name="no_spk"/>
        <field name="tanggal"/>
        <field name="user_id"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_smi_order_form" model="ir.ui.view">
    <field name="name">smi.order.form</field>
    <field name="model">smi.order</field>
    <field name="arch" type="xml">
      <form string="Order">
        <header>
          <button name="action_confirm" string="Konfirmasi" type="object"
                  class="oe_highlight" invisible="state != 'draft'"/>
          <button name="action_complete" string="Selesai" type="object"
                  class="oe_highlight" invisible="state != 'dikonfirmasi'"/>
          <button name="action_cancel" string="Batalkan" type="object"
                  invisible="state in ('selesai', 'dibatalkan')"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,dikonfirmasi,selesai"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1><field name="name" placeholder="Nama Pesanan"/></h1>
          </div>
          <group>
            <group>
              <field name="no_spk"/>
              <field name="tanggal"/>
            </group>
            <group>
              <field name="user_id" readonly="1"/>
            </group>
          </group>
          <notebook>
            <page string="Bahan Dibutuhkan">
              <field name="order_line_ids" readonly="state != 'draft'">
                <tree editable="bottom">
                  <field name="material_id"/>
                  <field name="jumlah_dibutuhkan"/>
                  <field name="mode_pick"/>
                  <field name="jumlah_terpenuhi" readonly="1"/>
                  <field name="is_sufficient" readonly="1"/>
                </tree>
              </field>
            </page>
            <page string="Detail Pengambilan" invisible="state == 'draft'">
              <field name="order_line_ids" readonly="1">
                <tree>
                  <field name="material_id"/>
                  <field name="jumlah_dibutuhkan"/>
                  <field name="mode_pick"/>
                  <field name="jumlah_terpenuhi"/>
                </tree>
              </field>
            </page>
            <page string="Catatan">
              <field name="catatan" nolabel="1"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_smi_order" model="ir.actions.act_window">
    <field name="name">Order</field>
    <field name="res_model">smi.order</field>
    <field name="view_mode">tree,form</field>
  </record>

  <!-- ======== Menu ======== -->
  <menuitem id="menu_smi_order" name="Order" parent="menu_smi_root"
            action="action_smi_order" sequence="20"
            groups="inventory_smi.group_admin,inventory_smi.group_kepala_produksi,inventory_smi.group_staf_produksi,inventory_smi.group_direktur"/>

</data>
</odoo>
